🗂️ Database and Table Management
1. Create a new database called company_db
CREATE DATABASE company_db;

2. Select the company_db database
USE company_db;

3. Create table skills
CREATE TABLE skills(
    skill_id INT IDENTITY(1,1) PRIMARY KEY,
    skill_name VARCHAR(50) NOT NULL,
    category VARCHAR(50)
);

4. Show all databases
SELECT name FROM sys.databases;

5. Show all tables in company_db
SELECT name FROM sys.tables;

6. Rename employee table to staff
EXEC sp_rename 'employee', 'staff';

📥 Data Insertion
7. Insert employee "Alice Green"
INSERT INTO employee(first_name,email,hire_date,salary,dept_id,gender)
VALUES ('Alice Green','alice.green@company.com','2024-01-10',62000,4,'Female');

8. Insert multiple projects
INSERT INTO project(project_name,budget,dept_id)
VALUES 
('Mobile App',60000,2),
('Training Program',25000,1);

9. Add new department
INSERT INTO department(dept_id,dept_name,location)
VALUES (8,'Sales','Boston');

10. Insert employee with partial data
INSERT INTO employee(first_name,email)
VALUES ('Tom','tom@company.com');


📊 Data Retrieval
11. Retrieve all employees
SELECT * FROM employee;

12. Select specific columns with alias
SELECT 
employee_id AS "Employee ID",
first_name AS "Name",
email AS "Email Address"
FROM employee;
13. Employees hired after Jan 1, 2023
SELECT * FROM employee
WHERE hire_date > '2023-01-01';

14. Projects with budget > 40000
SELECT * FROM project
WHERE budget > 40000
ORDER BY budget DESC;

15. Distinct locations
SELECT DISTINCT location FROM department;

🔄 Data Modification
16. Add phone_number column
ALTER TABLE employee
ADD phone_number VARCHAR(15);

17. Update salary of John Doe
UPDATE employee
SET salary = 65000
WHERE first_name = 'John Doe';

18. Update gender in IT department
UPDATE employee
SET gender = 'Other'
WHERE dept_id = 2;

19. Drop phone_number column
ALTER TABLE employee
DROP COLUMN phone_number;

🔍 Filtering & Conditions
20. Salary between 60000 and 80000
SELECT * FROM employee
WHERE salary BETWEEN 60000 AND 80000;

21. Names starting with J
SELECT * FROM employee
WHERE first_name LIKE 'J%';

22. Projects in dept 1 or 2
SELECT * FROM project
WHERE dept_id IN (1,2);

23. Email not NULL
SELECT * FROM employee
WHERE email IS NOT NULL;

24. Departments NOT in NY or Chicago
SELECT * FROM department
WHERE location NOT IN ('New York','Chicago');

25. Employees hired in 2023
SELECT * FROM employee
WHERE YEAR(hire_date) = 2023;

📈 Aggregate Functions
26. Total salary
SELECT SUM(salary) AS total_salary FROM employee;

27. Average budget
SELECT AVG(budget) FROM project;

28. Highest salary
SELECT MAX(salary) FROM employee;

29. Count employees in IT
SELECT COUNT(*) FROM employee
WHERE dept_id = 2;

30. Minimum budget
SELECT MIN(budget) FROM project;

🔗 Joins
31. Employees with department names
SELECT e.first_name, d.dept_name
FROM employee e
JOIN department d
ON e.dept_id = d.dept_id;

32. Departments with employee count
SELECT d.dept_name, COUNT(e.employee_id)
FROM department d
LEFT JOIN employee e
ON d.dept_id = e.dept_id
GROUP BY d.dept_name;

33. Projects with department names
SELECT p.project_name, d.dept_name
FROM project p
JOIN department d
ON p.dept_id = d.dept_id;

34. Employees in San Francisco
SELECT e.first_name
FROM employee e
JOIN department d
ON e.dept_id = d.dept_id
WHERE d.location = 'San Francisco';

35. Departments with no projects
SELECT d.dept_name
FROM department d
LEFT JOIN project p
ON d.dept_id = p.dept_id
WHERE p.project_id IS NULL;

🔤 Functions
36. Full Name
SELECT first_name + ' ' + last_name AS Full_Name
FROM employee;

37. Uppercase department names
SELECT UPPER(dept_name) FROM department;

38. First 3 characters of email
SELECT SUBSTRING(email,1,3) FROM employee;

39. Absolute value
SELECT ABS(-50000);

40. Round average salary
SELECT ROUND(AVG(salary),2) FROM employee;

🚀 Advanced Queries
41. Top 3 recent employees
SELECT TOP 3 *
FROM employee
ORDER BY hire_date DESC;

42. Pagination (records 4–6)
SELECT *
FROM employee
ORDER BY employee_id
OFFSET 3 ROWS FETCH NEXT 3 ROWS ONLY;

43. Salary classification
SELECT first_name,
CASE
    WHEN salary >= 70000 THEN 'High'
    ELSE 'Low'
END AS salary_status
FROM employee;

44. Budget category
SELECT project_name,
CASE
    WHEN budget >= 60000 THEN 'Large'
    WHEN budget >= 40000 THEN 'Medium'
    ELSE 'Small'
END AS category
FROM project;

45. Total budget per department
SELECT dept_id, SUM(budget)
FROM project
GROUP BY dept_id;

46. Longest name
SELECT *
FROM employee
WHERE LEN(first_name) = (SELECT MAX(LEN(first_name)) FROM employee);

47. Last 90 days employees
SELECT *
FROM employee
WHERE hire_date >= DATEADD(DAY,-90,'2025-03-22');

🗑️ Deletion & Cleanup
48. Delete employees with salary < 60000
DELETE FROM employee
WHERE salary < 60000;

49. Drop project table
DROP TABLE project;

50. Backup & Restore
-- Restore
RESTORE DATABASE company_db
FROM DISK = 'C:\Backup\company_db.bak'
WITH REPLACE;

-- Verify
USE company_db;
EXEC sp_helpfile;

-- Delete DB
USE master;
DROP DATABASE company_db;
